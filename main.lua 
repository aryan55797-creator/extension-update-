        pcall(function() mediaPlayer.release() end)
    end
    mediaPlayer = MediaPlayer()
end

function writeWavHeader(outStream, totalAudioLen)
    local sampleRate = 24000
    local channels = 1
    local bitsPerSample = 16
    local byteRate = sampleRate * channels * (bitsPerSample / 8)
    local blockAlign = channels * (bitsPerSample / 8)
    local totalSize = totalAudioLen + 36
    local function getBytes(val) return {val & 0xff, (val >> 8) & 0xff, (val >> 16) & 0xff, (val >> 24) & 0xff} end
    local tsB = getBytes(totalSize)
    local srB = getBytes(sampleRate)
    local brB = getBytes(byteRate)
    local dlB = getBytes(totalAudioLen)
    local header = {0x52,0x49,0x46,0x46,tsB[1],tsB[2],tsB[3],tsB[4],0x57,0x41,0x56,0x45,0x66,0x6d,0x74,0x20,0x10,0x00,0x00,0x00,0x01,0x00,0x01,0x00,srB[1],srB[2],srB[3],srB[4],brB[1],brB[2],brB[3],brB[4],blockAlign,0x00,bitsPerSample,0x00,0x64,0x61,0x74,0x61,dlB[1],dlB[2],dlB[3],dlB[4]}
    for i=1,#header do outStream.write(header[i]) end
end

-- मुख्य जनरेशन फंक्शन (प्रॉम्प्ट और सेफ्टी के साथ)
function generateSimpleAudio(text, voice, apikey, model, emotion, generateBtn, playBtn, resultLayout)
    local apiUrl = "https://generativelanguage.googleapis.com/v1beta/models/" .. model .. ":generateContent?key=" .. apikey
    local styledText = "Style instruction: Speak the following text in a " .. emotion .. " tone. Text: " .. text
    
    local requestBody = {
        contents = {{ parts = {{ text = styledText }} }},
        safetySettings = safetySettings,
        generationConfig = {
            responseModalities = {"AUDIO"},
            speechConfig = { voiceConfig = { prebuiltVoiceConfig = { voiceName = voice } } }
        }
    }
    
    Http.post(apiUrl, cjson.encode(requestBody), {["Content-Type"]="application/json"}, function(code, content)
        if code == 200 then
            local ok, data = pcall(cjson.decode, content)
            if ok and data.candidates then
                local base64Audio = data.candidates[1].content.parts[1].inlineData.data
                local audioBytes = Base64.decode(base64Audio, Base64.NO_WRAP)
                local tempPath = context.getCacheDir().getPath() .. "/tts_" .. os.time() .. ".wav"
                local fos = FileOutputStream(File(tempPath))
                writeWavHeader(fos, #audioBytes)
                fos.write(audioBytes)
                fos.close()
                generatedAudioPath = tempPath
                mainHandler.post(Runnable({run=function()
                    resultLayout.setVisibility(View.VISIBLE)
                    initMediaPlayer()
                    mediaPlayer.setDataSource(generatedAudioPath)
                    mediaPlayer.prepare()
                    playBtn.setEnabled(true)
                    generateBtn.setText("REGENERATE")
                    generateBtn.setEnabled(true)
                    showToast("Generated with " .. emotion .. " tone!")
                end}))
            end
        else
            showToast("Error: " .. code)
            mainHandler.post(Runnable({run=function() generateBtn.setEnabled(true); generateBtn.setText("GENERATE") end}))
        end
    end)
end

